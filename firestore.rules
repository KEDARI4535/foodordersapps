rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - role: string (required, ['customer', 'delivery', 'owner', 'admin'])
    //   - phoneNumber: string (optional)
    //
    // Collection: restaurants
    // Fields:
    //   - name: string (required)
    //   - cuisine: string (required)
    //   - ownerUid: string (required)
    //   - location: map (required)
    //   - menu: list (required)
    //
    // Collection: orders
    // Fields:
    //   - customerUid: string (required)
    //   - restaurantId: string (required)
    //   - status: string (required)
    //   - deliveryAgentUid: string (optional)
    //
    // Collection: notifications
    // Fields:
    //   - userId: string (required)
    //   - read: boolean (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "kedarisrinivasnaidu333@gmail.com" && request.auth.token.email_verified == true ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }
    
    function isRestaurantOwner(restaurantId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/restaurants/$(restaurantId)) && 
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      // Allow user to read their own profile or admin to read all
      allow read: if isOwner(userId) || isAdmin();
      // Allow user to create/update their own profile
      allow create, update: if isOwner(userId);
    }

    match /restaurants/{restaurantId} {
      // Allow anyone (even unauthenticated) to read restaurants for browsing
      allow read, list: if true;
      // Only owners or admins can create/update/delete
      allow create: if isAuthenticated() && (request.resource.data.ownerUid == request.auth.uid || isAdmin());
      allow update, delete: if isRestaurantOwner(restaurantId) || isAdmin();
    }

    match /orders/{orderId} {
      // Allow customers, delivery agents, restaurant owners, or admins to read orders
      allow read, list: if isAuthenticated() && (
        request.auth.uid == resource.data.customerUid || 
        request.auth.uid == resource.data.deliveryAgentUid ||
        (exists(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)) && 
         get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerUid == request.auth.uid) ||
        isAdmin()
      );
      // Allow customers to create orders
      allow create: if isAuthenticated() && request.resource.data.customerUid == request.auth.uid;
      // Allow updates for specific fields based on role
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.customerUid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'status'])) ||
        (request.auth.uid == resource.data.deliveryAgentUid && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'deliveryLocation', 'deliveryAgentUid', 'deliveryPhone'])) ||
        (resource.data.status == 'placed' && request.resource.data.status == 'preparing' && request.resource.data.deliveryAgentUid == request.auth.uid) ||
        isAdmin()
      );
    }

    match /notifications/{notificationId} {
      // Allow users to read their own notifications
      allow read, list: if isAuthenticated() && request.auth.uid == resource.data.userId;
      // Allow system to create notifications (triggered by app logic)
      allow create: if isAuthenticated();
      // Allow users to mark their own notifications as read
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
